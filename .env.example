# Postgres connection for the data_warehouse database.
# For local dev these point at the docker-compose Postgres restored from Data_Warehouse.backup.
# For production, point these at the real Rowad data warehouse host and use a
# least-privilege read-only role scoped to the 3 whitelisted tables (see README).
DB_HOST=localhost
DB_PORT=5433
DB_NAME=data_warehouse
DB_USER=rowad_agent
DB_PASSWORD=rowad_agent_local_dev
DB_STATEMENT_TIMEOUT_MS=8000

# Local Ollama server running the gemma4:e4b model (kept for reference/rollback,
# see app/llm.py - not currently used since OPENAI_API_KEY below is active).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# OpenAI API - currently the active LLM backend (see app/llm.py).
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

SQL_MAX_ROWS=200
SQL_MAX_REPAIR_ATTEMPTS=2

# Every route except /health requires a per-user account (HTTP Basic Auth
# checked against the users table in data/app.db). These two vars create one
# account on first run ONLY if no users exist yet, so you're not locked out -
# after that, add/remove accounts with: uv run python -m app.manage add-user <name>
BOOTSTRAP_ADMIN_USERNAME=change-me
BOOTSTRAP_ADMIN_PASSWORD=change-me
