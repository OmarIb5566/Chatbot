run = "pip install -r requirements.txt && python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT"
modules = ["python-3.12"]

[deployment]
deploymentTarget = "cloudrun"

[userenv]

[userenv.shared]
DB_NAME = "data_warehouse"
DB_STATEMENT_TIMEOUT_MS = "8000"
DB_USER = "rowad_agent"
OLLAMA_MODEL = "gemma4:e4b"
SQL_MAX_REPAIR_ATTEMPTS = "2"
SQL_MAX_ROWS = "200"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn app.main:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[nix]
channel = "stable-25_05"
packages = ["cacert", "cargo", "libiconv", "libxcrypt", "libyaml", "rustc"]

[[ports]]
localPort = 5000
externalPort = 80
